<% layout ("/layouts/boilerplate") %>
<body>
    <h3>All Listing</h3>
    <form action="/listings/new" method="GET">
        <button> create new listing </button>
    </form>
    <ul>
        <% for(let listing of allListing) { %>
            <li><a href="/listings/<%= listing._id %>"><%= listing.title %></a></li>
        <% } %>
    </ul>
</body>